models/
pending/
evaluated/
reports/

# 校準模型快照屬執行產物；資料集可保留版控
calibration/models/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version

# 環境變數與虛擬環境
.env
.env.*
venv/
.venv/

# 作業系統與編輯器
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
.idea/

