# ====================================
# 排除大型模型文件和數據目錄
# ====================================
models/
pending/
evaluated/
kg/

# ====================================
# Python 緩存和編譯文件
# ====================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ====================================
# 虛擬環境
# ====================================
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ====================================
# IDE 和編輯器配置
# ====================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ====================================
# Git 相關
# ====================================
.git/
.gitignore
.gitattributes

# ====================================
# 測試和覆蓋率
# ====================================
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
.hypothesis/
htmlcov/
*.cover
.mypy_cache/
.dmypy.json
dmypy.json

# ====================================
# 文檔和報告（不需要在容器中）
# ====================================
*.md
*.txt
!requirements.txt
*.xlsx
*.xls
*.doc
*.docx
*.pdf

# ====================================
# 多媒體文件（應透過 volumes 掛載）
# ====================================
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.ico
*.svg
*.mp3
*.mp4
*.wav
*.avi
*.mov

# ====================================
# JSON 和 HTML 報告（運行時生成）
# ====================================
*.json
!aspects_sources.yaml
*.html

# ====================================
# 日誌和臨時文件
# ====================================
*.log
*.tmp
*.temp
pip-log.txt
pip-delete-this-directory.txt

# ====================================
# Docker 相關（避免遞迴）
# ====================================
Dockerfile*
docker-compose*.yml
.dockerignore

# ====================================
# 其他不需要的文件
# ====================================
*.sqlite
*.db
.env
.env.local

