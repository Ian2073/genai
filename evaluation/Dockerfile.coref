FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

# 設置非互動模式
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Taipei

# 安裝基本工具和 Python 3.11
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev \
        python3-pip curl wget build-essential \
        software-properties-common gnupg2 \
        && rm -rf /var/lib/apt/lists/*



# 設置 Python 3.11 為默認
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

WORKDIR /app

# 升級 pip 和基礎工具
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# 安裝 PyTorch（CUDA 12.4 支援 Blackwell 架構）
RUN pip install --no-cache-dir --extra-index-url https://download.pytorch.org/whl/cu124 \
    torch torchvision torchaudio

# 安裝 transformers 生態 + fastcoref
RUN pip install --no-cache-dir \
    transformers==4.39.3 \
    accelerate==0.27.2 \
    tokenizers==0.15.2 \
    safetensors==0.4.2 \
    fastcoref==2.1.6 \
    "numpy<2.0" \
    fastapi==0.95.2 \
    uvicorn==0.22.0 \
    pydantic==1.10.13

# 只複製必要的服務文件（root context）
COPY evaluation/coref.py /app/coref.py

# 創建模型目錄（將由 volumes 掛載填充）
RUN mkdir -p /app/models

EXPOSE 8001

CMD ["uvicorn", "coref:app", "--host", "0.0.0.0", "--port", "8001"]


